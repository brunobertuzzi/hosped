{
    "name": "hosped",
    "version": "1.0.0",
    "private": true,
    "description": "Plataforma de Gestão Hoteleira",
    "scripts": {
        "dev:backend": "dotenv -e .env -- npm --prefix backend run start:dev",
        "dev:frontend": "dotenv -e .env -- npm --prefix frontend run dev",
        "install:all": "npm install --prefix backend && npm install --prefix frontend",
        "build:backend": "dotenv -e .env -- npm --prefix backend run build",
        "build:frontend": "dotenv -e .env -- npm --prefix frontend run build",
        "lint:backend": "npm --prefix backend run lint",
        "lint:frontend": "npm --prefix frontend run lint"
    },
    "devDependencies": {
        "dotenv-cli": "^11.0.0"
    }
}
