# ==============================================================
# UNIFIED ENVIRONMENT VARIABLES (.env.example)
# Copie para backend/.env e ajuste com seus valores reais.
# Em produção (Railway), cadastre APENAS nas Railway Variables.
# ==============================================================

# -----------------------
# DATABASE (PostgreSQL) — OBRIGATÓRIO
# Em produção, usar a URL fornecida pelo Railway PostgreSQL plugin.
# -----------------------
DATABASE_URL="postgresql://postgres:SUA_SENHA@host:5432/hotel_sistema?schema=public"

# -----------------------
# BACKEND (NestJS API) — OBRIGATÓRIOS
# -----------------------
PORT=3001
# Gere com: openssl rand -base64 64
JWT_SECRET="SUBSTITUA_POR_UM_SEGREDO_FORTE_DE_64_CHARS_MINIMO"
JWT_EXPIRES_IN="7d"

# -----------------------
# REDIS (Filas e Cache) — OBRIGATÓRIO
# Em produção, usar o host/port fornecidos pelo Railway Redis plugin.
# -----------------------
REDIS_HOST="localhost"
REDIS_PORT=6379

# -----------------------
# FRONTEND (Next.js) — OBRIGATÓRIO
# FRONTEND_URL: URL pública do frontend em produção (sem barra final)
# NEXT_PUBLIC_API_URL: URL pública da API em produção
# -----------------------
NEXT_PUBLIC_API_URL="https://sua-api.railway.app"
FRONTEND_URL="https://seu-frontend.railway.app"

# -----------------------
# SISTEMA BILLING GATEWAY — OPCIONAL (billing Sistema não funciona sem)
# Token e chave pública do Mercado Pago (conta da plataforma, não dos hotéis)
# -----------------------
SISTEMA_PAYMENT_PROVIDER="MERCADO_PAGO"
SISTEMA_PAYMENT_TOKEN="seu_access_token_do_mercado_pago"
SISTEMA_PAYMENT_PUB_KEY="sua_chave_publica_do_mercado_pago"

# -----------------------
# SUPER ADMIN — OBRIGATÓRIO para seed inicial
# Criado automaticamente na primeira execução se não existir.
# -----------------------
SUPER_ADMIN_EMAIL="admin@seudominio.com"
SUPER_ADMIN_PASSWORD="SenhaForteAqui123!"
