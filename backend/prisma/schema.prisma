datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  PLATFORM_OWNER
  HOTEL_OWNER
  MANAGER
  RECEPTIONIST
  FINANCIAL
  INVENTORY
  HOUSEKEEPING
  MAINTENANCE
}

enum RoomStatus {
  DISPONIVEL
  OCUPADO
  LIMPEZA
  MANUTENCAO
  BLOQUEADO
}

enum ReservationStatus {
  PENDENTE
  CONFIRMADA
  CHECK_IN_REALIZADO
  HOSPEDADO
  CHECK_OUT_REALIZADO
  CANCELADA
  NO_SHOW
}

enum MaintenanceStatus {
  ABERTA
  EM_ANDAMENTO
  CONCLUIDA
}

enum MovementType {
  ENTRADA
  SAIDA
  AJUSTE
}

enum PaymentMethod {
  PIX
  CARTAO
  DINHEIRO
}

enum AuditAction {
  LOGIN
  CRIAR
  ATUALIZAR
  DELETAR
  CANCELAR
  ESTORNO
  MUDANCA_STATUS
}

enum ExpenseStatus {
  PENDENTE
  PAGO
  CANCELADO
}

enum CleaningStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDO
}

enum WebhookStatus {
  RECEBIDO
  PROCESSADO
  FALHA
}

enum InvoiceStatus {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum AnnouncementType {
  INFO
  WARNING
  SUCCESS
  RELEASE_NOTES
}

model Hotel {
  id                   String    @id @default(uuid())
  nome                 String
  razaoSocial          String
  documentoFiscal      String    @unique
  email                String    @unique
  telefone             String
  logo                 String?
  cores                Json? // Cores customizadas: { primary, secondary, text }
  banner               String?
  endereco             String
  politicaCancelamento String?
  slogan               String?
  descricaoPublica     String?
  diferenciais         String[]
  plan                 String    @default("STARTUP")
  status               String    @default("ACTIVE")
  mrr                  Float     @default(150.0)
  nextBillingDate      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relacionamentos
  branches           Branch[]
  users              User[]
  roomCategories     RoomCategory[]
  rooms              Room[]
  reservations       Reservation[]
  guests             Guest[]
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
  consumptions       Consumption[]
  payments           Payment[]
  maintenanceOrders  MaintenanceOrder[]
  auditLogs          AuditLog[]
  integration        HotelIntegration?
  systemErrorLogs    SystemErrorLog[]

  // Novas Relacoes (Sistema V2)
  tariffs        Tariff[]
  seasons        Season[]
  expenses       Expense[]
  cleaningTasks  CleaningTask[]
  webhookEvents  WebhookEvent[]
  icalSyncs      IcalSync[]
  systemInvoices SystemInvoice[]
}

model Branch {
  id        String   @id @default(uuid())
  hotelId   String   @map("hotel_id")
  nome      String
  endereco  String
  cidade    String
  estado    String
  telefone  String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  hotel          Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rooms          Room[]
  reservations   Reservation[]
  inventoryItems InventoryItem[]
  users          User[]

  @@index([hotelId])
}

model User {
  id          String   @id @default(uuid())
  hotelId     String?  @map("hotel_id") // Nulo para Platform Owner
  branchId    String?  @map("branch_id")
  nome        String
  email       String   @unique
  password    String
  role        Role     @default(RECEPTIONIST)
  permissions String[] // ex: ["reservations.create", "rooms.manage"]
  status      String   @default("ATIVO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamentos
  hotel             Hotel?             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  branch            Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  auditLogs         AuditLog[]
  systemErrorLogs   SystemErrorLog[]
  maintenanceOrders MaintenanceOrder[] @relation("ResponsibleStaff")
  cleaningTasks     CleaningTask[]

  @@index([hotelId])
  @@index([branchId])
}

model RoomCategory {
  id               String   @id @default(uuid())
  hotelId          String   @map("hotel_id")
  nome             String
  descricao        String?
  capacidadeMaxima Int
  comodidades      String[]
  fotos            String[]
  valorBase        Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relacionamentos
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rooms        Room[]
  reservations Reservation[]
  tariffs      Tariff[]
  icalSyncs    IcalSync[]

  @@index([hotelId])
}

model Room {
  id          String     @id @default(uuid())
  hotelId     String     @map("hotel_id")
  branchId    String     @map("branch_id")
  categoryId  String     @map("category_id")
  numero      String
  status      RoomStatus @default(DISPONIVEL)
  observacoes String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relacionamentos
  hotel             Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  branch            Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category          RoomCategory       @relation(fields: [categoryId], references: [id])
  reservations      Reservation[]
  maintenanceOrders MaintenanceOrder[]
  cleaningTasks     CleaningTask[]
  icalSyncs         IcalSync[]

  @@index([hotelId])
  @@index([branchId])
  @@index([categoryId])
}

model Guest {
  id        String   @id @default(uuid())
  hotelId   String   @map("hotel_id")
  nome      String
  documento String // RG ou CPF
  email     String
  telefone  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([hotelId, documento])
  @@index([hotelId])
}

model Reservation {
  id               String            @id @default(uuid())
  hotelId          String            @map("hotel_id")
  branchId         String            @map("branch_id")
  guestId          String            @map("guest_id")
  categoryId       String            @map("category_id")
  roomId           String?           @map("room_id") // Nulo até o check-in ou definição
  dataCheckIn      DateTime
  dataCheckOut     DateTime
  valorTotal       Decimal           @db.Decimal(10, 2)
  status           ReservationStatus @default(PENDENTE)
  origem           String // "ONLINE", "RECEPCAO", "OTA_AIRBNB", "OTA_BOOKING", etc.
  documentoCheckIn String? // Documento apresentado no check-in
  checkInAt        DateTime?
  checkOutAt       DateTime?
  otaReservationId String? // ID da reserva na OTA (ex: Booking, Airbnb) para evitar duplicatas
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relacionamentos
  hotel        Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  guest        Guest         @relation(fields: [guestId], references: [id])
  category     RoomCategory  @relation(fields: [categoryId], references: [id])
  room         Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  consumptions Consumption[]
  payments     Payment[]

  @@unique([hotelId, otaReservationId])
  @@index([hotelId])
  @@index([branchId])
  @@index([guestId])
  @@index([roomId])
  @@index([branchId, categoryId, status, dataCheckIn, dataCheckOut]) // Otimização para overbooking
}

model InventoryItem {
  id            String   @id @default(uuid())
  hotelId       String   @map("hotel_id")
  branchId      String   @map("branch_id")
  nome          String
  categoria     String // "BEBIDA", "SNACK", "LAVANDERIA", "PRODUTO_HIGIENE"
  unidade       String // "UN", "L", "KG"
  quantidade    Int      @default(0)
  estoqueMinimo Int      @default(5)
  valorVenda    Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  hotel     Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  branch    Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]

  @@index([hotelId])
  @@index([branchId])
}

model InventoryMovement {
  id         String       @id @default(uuid())
  itemId     String       @map("item_id")
  hotelId    String       @map("hotel_id")
  tipo       MovementType
  quantidade Int
  motivo     String? // "VENDA_CONSUMO", "COMPRA_ESTOQUE", "PERDA", "AJUSTE"
  createdAt  DateTime     @default(now())

  // Relacionamentos
  item  InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  hotel Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([hotelId])
}

model Consumption {
  id            String   @id @default(uuid())
  reservationId String   @map("reservation_id")
  hotelId       String   @map("hotel_id")
  descricao     String
  quantidade    Int
  valorUnitario Decimal  @db.Decimal(10, 2)
  valorTotal    Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  // Relacionamentos
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  hotel       Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([hotelId])
}

model Payment {
  id            String        @id @default(uuid())
  hotelId       String        @map("hotel_id")
  reservationId String        @map("reservation_id")
  valor         Decimal       @db.Decimal(10, 2)
  metodo        PaymentMethod
  status        String // "APROVADO", "PENDENTE", "ESTORNADO"
  transacaoId   String? // Id do gateway (ex: Mercado Pago)
  createdAt     DateTime      @default(now())

  // Relacionamentos
  hotel       Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([reservationId])
}

model MaintenanceOrder {
  id            String            @id @default(uuid())
  roomId        String            @map("room_id")
  hotelId       String            @map("hotel_id")
  descricao     String
  status        MaintenanceStatus @default(ABERTA)
  responsavelId String?           @map("responsavel_id")
  observacoes   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relacionamentos
  room        Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  hotel       Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  responsavel User? @relation("ResponsibleStaff", fields: [responsavelId], references: [id])

  @@index([roomId])
  @@index([hotelId])
  @@index([status, roomId])
}

model AuditLog {
  id              String      @id @default(uuid())
  hotelId         String      @map("hotel_id")
  userId          String?     @map("user_id")
  acao            AuditAction
  entidade        String // "RESERVATION", "PAYMENT", "ROOM", etc
  dadosAnteriores Json?
  dadosNovos      Json?
  createdAt       DateTime    @default(now())

  // Relacionamentos
  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([userId])
}

model HotelIntegration {
  id                     String   @id @default(uuid())
  hotelId                String   @unique @map("hotel_id")
  googlePlaceId          String? // Avaliações do Google
  tripAdvisorId          String? // Avaliações do Tripadvisor
  whatsappToken          String? // API do WhatsApp
  whatsappNumber         String?
  whatsappApiUrl         String? // URL da API (ex: Evolution API)
  channelManagerId       String? // ID do Channel Manager (ex: Cloudbeds)
  bookingEngineUrl       String? // Link do Motor de Reservas Direto
  paymentGatewayProvider String? // "MERCADO_PAGO", "STRIPE", "ASISTEMA", etc.
  paymentGatewayToken    String? // Token Secreto/Private Key do Gateway do Hotel
  paymentGatewayPubKey   String? // Chave Pública do Gateway do Hotel
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
}

model SystemErrorLog {
  id           String   @id @default(uuid())
  hotelId      String?  @map("hotel_id")
  userId       String?  @map("user_id")
  route        String?
  method       String?
  statusCode   Int?
  errorMessage String
  stackTrace   String?
  createdAt    DateTime @default(now())

  // Relacionamentos opcionais se tiver hotel
  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([hotelId])
  @@index([userId])
  @@index([createdAt])
}

model Season {
  id         String   @id @default(uuid())
  hotelId    String   @map("hotel_id")
  nome       String // Ex: Alta Temporada, Baixa Temporada, Feriado
  dataInicio DateTime
  dataFim    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hotel   Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  tariffs Tariff[]

  @@index([hotelId])
}

model Tariff {
  id           String   @id @default(uuid())
  hotelId      String   @map("hotel_id")
  seasonId     String   @map("season_id")
  categoryId   String   @map("category_id")
  valor        Decimal  @db.Decimal(10, 2)
  minimoNoites Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel    Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  season   Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  category RoomCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([hotelId])
  @@index([categoryId])
}

model Expense {
  id             String        @id @default(uuid())
  hotelId        String        @map("hotel_id")
  descricao      String
  valor          Decimal       @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         ExpenseStatus @default(PENDENTE)
  categoria      String // FIXA, VARIAVEL, IMPOSTO
  fornecedor     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model CleaningTask {
  id            String         @id @default(uuid())
  hotelId       String         @map("hotel_id")
  roomId        String         @map("room_id")
  responsavelId String?        @map("responsavel_id")
  status        CleaningStatus @default(PENDENTE)
  tipoLimpeza   String // EX: "TROCADE_ENXOVAL", "LIMPEZA_SAIDA", "LIMPEZA_GERAL"
  observacoes   String?
  iniciadaEm    DateTime?
  finalizadaEm  DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  hotel       Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room        Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  responsavel User? @relation(fields: [responsavelId], references: [id])

  @@index([hotelId])
  @@index([roomId])
}

model WebhookEvent {
  id          String        @id @default(uuid())
  hotelId     String?       @map("hotel_id")
  provider    String // "MERCADO_PAGO", "CLOUDBEDS"
  eventType   String
  payload     Json
  status      WebhookStatus @default(RECEBIDO)
  errorReason String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  hotel Hotel? @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model IcalSync {
  id         String  @id @default(uuid())
  hotelId    String  @map("hotel_id")
  roomId     String? @map("room_id")
  categoryId String? @map("category_id")

  // URLs to fetch from OTAs
  importUrls String[] // Array of iCal URLs from Airbnb, Booking, etc.

  // URL to expose to OTAs (auto-generated token)
  exportToken String @unique @default(uuid())

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotel    Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room     Room?         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  category RoomCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model SystemPlan {
  id          String   @id @default(uuid())
  name        String   @unique // ex: STARTUP, PRO, ENTERPRISE
  description String?
  price       Decimal  @db.Decimal(10, 2)
  maxBranches Int      @default(1)
  maxRooms    Int      @default(20) // -1 for unlimited
  maxUsers    Int      @default(5)
  features    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemInvoice {
  id          String        @id @default(uuid())
  hotelId     String        @map("hotel_id")
  amount      Decimal       @db.Decimal(10, 2)
  status      InvoiceStatus @default(PENDENTE)
  dueDate     DateTime
  paidAt      DateTime?
  periodStart DateTime?
  periodEnd   DateTime?
  paymentLink String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique // ex: "BETA_CHANNEL_MANAGER"
  description String?
  isEnabled   Boolean  @default(false)
  tenantIds   String[] // Array of hotelIds that have this feature enabled se nao for global
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemAnnouncement {
  id          String           @id @default(uuid())
  title       String
  content     String
  type        AnnouncementType @default(INFO)
  isActive    Boolean          @default(true)
  targetPlans String[] // Vazio = todos os planos
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}
